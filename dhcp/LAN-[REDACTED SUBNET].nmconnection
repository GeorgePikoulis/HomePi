#/etc/NetworkManager/system-connections/LAN-[REDACTED SUBNET].nmconnection
[connection]
id=LAN-[REDACTED SUBNET]
uuid=[REDACTED UUID]
type=ethernet
autoconnect-priority=10
interface-name=eth1
timestamp=1755514503
wait-device-timeout=30

[ethernet]

[ipv4]
address1=[REDACTED SUBNET].1/24
method=manual

[ipv6]
addr-gen-mode=default
method=ignore

[proxy]
